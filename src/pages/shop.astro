---
export const prerender = false;
import Base from "../layouts/Base.astro";
import { anonClient } from "../lib/supabase";

const sb = anonClient();
let products: any[] = [];
if (sb) {
  const { data } = await sb.from("products").select("id, slug, name, description, price_pence, compare_at_pence, currency, image_url, tags, is_digital").not("published_at", "is", null).order("created_at", { ascending: false });
  products = data || [];
}

const siteUrl = import.meta.env.PUBLIC_SITE_URL || "https://harmony-threads-xk7m2.vercel.app";
const collectionSchema = { "@context": "https://schema.org", "@type": "CollectionPage", "name": "All Products — Harmony Threads", "url": `${siteUrl}/shop`, "mainEntity": { "@type": "ItemList", "itemListElement": products.map((p: any, i: number) => ({ "@type": "ListItem", "position": i + 1, "url": `${siteUrl}/products/${p.slug}`, "name": p.name })) } };
---

<Base title="Shop All Products | Harmony Threads" description="Browse the full Harmony Threads collection — iconic band tees, music history eBooks, and lifestyle goods." structuredData={collectionSchema}>
  <div class="max-w-7xl mx-auto px-6 lg:px-8 py-12">
    <div class="mb-12">
      <p class="text-xs uppercase tracking-[0.2em] font-medium mb-2" style="color: var(--accent);">All products</p>
      <h1 class="font-display text-4xl md:text-5xl font-semibold tracking-tight" style="color: var(--ink);">The full collection.</h1>
    </div>
    <div class="flex flex-wrap gap-3 mb-10">
      <button data-filter="all" class="filter-btn px-4 py-2 text-xs font-semibold rounded-full border transition-all" style="background: var(--ink); color: var(--paper); border-color: var(--ink);">All</button>
      <button data-filter="physical" class="filter-btn px-4 py-2 text-xs font-medium rounded-full border transition-all" style="border-color: var(--border); color: var(--muted);">Physical</button>
      <button data-filter="digital" class="filter-btn px-4 py-2 text-xs font-medium rounded-full border transition-all" style="border-color: var(--border); color: var(--muted);">Digital</button>
    </div>
    {products.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8" id="product-grid">
        {products.map((product: any) => {
          const currencySymbol = product.currency === 'GBP' ? '£' : '$';
          const comparePrice = product.compare_at_pence ? (product.compare_at_pence / 100).toFixed(2) : null;
          return (
            <a href={`/products/${product.slug}`} class="group block product-card" data-type={product.is_digital ? 'digital' : 'physical'}>
              <div class="overflow-hidden rounded-xl mb-4 relative" style="background: #f0ebe2; aspect-ratio: 4/5;">
                {product.image_url ? (<img src={product.image_url} alt={product.name} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />) : (<div class="w-full h-full flex items-center justify-center font-display text-6xl font-bold opacity-10" style="color: var(--ink);">H</div>)}
                {product.is_digital && <span class="absolute top-3 left-3 text-xs px-2 py-1 rounded-full font-medium" style="background: var(--ink); color: var(--paper);">Digital</span>}
                {comparePrice && <span class="absolute top-3 right-3 text-xs px-2 py-1 rounded-full font-semibold" style="background: var(--accent); color: white;">Sale</span>}
              </div>
              <div class="flex items-start justify-between gap-3">
                <div><h2 class="font-medium text-sm leading-snug">{product.name}</h2><p class="text-xs mt-1" style="color: var(--muted);">Harmony Threads</p></div>
                <div class="text-right shrink-0"><span class="font-display font-semibold text-sm block">{currencySymbol}{(product.price_pence / 100).toFixed(2)}</span>{comparePrice && <span class="text-xs line-through" style="color: var(--muted);">{currencySymbol}{comparePrice}</span>}</div>
              </div>
            </a>
          );
        })}
      </div>
    ) : (
      <div class="text-center py-24"><p class="font-display text-2xl font-semibold mb-3" style="color: var(--ink);">Products loading…</p></div>
    )}
  </div>
  <script>
    document.querySelectorAll('.filter-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const filter = (btn as HTMLElement).dataset.filter;
        document.querySelectorAll('.filter-btn').forEach(b => { (b as HTMLElement).style.background = ''; (b as HTMLElement).style.color = 'var(--muted)'; (b as HTMLElement).style.borderColor = 'var(--border)'; });
        (btn as HTMLElement).style.background = 'var(--ink)'; (btn as HTMLElement).style.color = 'var(--paper)'; (btn as HTMLElement).style.borderColor = 'var(--ink)';
        document.querySelectorAll('.product-card').forEach(card => { const el = card as HTMLElement; if (filter === 'all' || el.dataset.type === filter) { el.style.display = ''; } else { el.style.display = 'none'; } });
      });
    });
  </script>
</Base>
