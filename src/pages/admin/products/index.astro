---
export const prerender = false;
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { ssrClient } from "../../../lib/supabase";

const sb = ssrClient(Astro.cookies);
const { data: { user } } = await sb.auth.getUser();
if (!user) return Astro.redirect("/login?next=/admin/products");
const { data: admin } = await sb.from("admins").select("email").eq("email", user.email ?? "").maybeSingle();
if (!admin) return new Response("Forbidden", { status: 403 });

const { data: products } = await sb.from("products").select("id, slug, name, price_pence, currency, published_at").order("created_at", { ascending: false });
---
<AdminLayout title="Products">
  <div class="bg-white rounded-lg border overflow-hidden" style="border-color: #e5e7eb;">
    <table class="w-full text-sm">
      <thead style="background: #f9fafb;"><tr><th class="text-left px-4 py-3 font-medium">Product</th><th class="text-left px-4 py-3 font-medium">Slug</th><th class="text-right px-4 py-3 font-medium">Price</th><th class="text-center px-4 py-3 font-medium">Status</th><th class="px-4 py-3"></th></tr></thead>
      <tbody>
        {(products || []).map((p: any) => (
          <tr class="border-t" style="border-color: #f3f4f6;">
            <td class="px-4 py-3 font-medium">{p.name}</td>
            <td class="px-4 py-3 font-mono text-xs" style="color: #6b7280;">{p.slug}</td>
            <td class="px-4 py-3 text-right">{p.currency} {(p.price_pence / 100).toFixed(2)}</td>
            <td class="px-4 py-3 text-center"><span class={`text-xs px-2 py-0.5 rounded-full ${p.published_at ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500'}`}>{p.published_at ? 'Live' : 'Draft'}</span></td>
            <td class="px-4 py-3 text-right"><a href={`/admin/products/${p.id}`} class="text-xs font-medium underline" style="color: #c2410c;">Edit</a></td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</AdminLayout>
