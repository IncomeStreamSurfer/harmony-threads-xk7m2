---
import "../styles/global.css";

interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title} — Admin | Harmony Threads</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body style="background: #f4f4f4; color: #111; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;">
  <header style="background: #1a1209; color: white; padding: 0 24px;" class="flex items-center justify-between h-14">
    <div class="flex items-center gap-4">
      <a href="/" class="text-sm font-semibold" style="color: #f97316;">HarmonyThreads</a>
      <span style="color: #444;">/</span>
      <span class="text-sm" style="color: #ccc;">Admin</span>
    </div>
    <nav class="flex items-center gap-4 text-xs" style="color: #999;">
      <a href="/admin" class="hover:text-white transition-colors">Dashboard</a>
      <a href="/admin/products" class="hover:text-white transition-colors">Products</a>
      <a href="/admin/pages" class="hover:text-white transition-colors">Pages</a>
      <a href="/admin/content" class="hover:text-white transition-colors">Blog</a>
      <a href="/" class="hover:text-white transition-colors">← Site</a>
    </nav>
  </header>
  <main class="max-w-6xl mx-auto px-6 py-8">
    <h1 class="text-2xl font-semibold mb-6">{title}</h1>
    <slot />
  </main>
</body>
</html>
